APP_MODE=server
DATABASE_URL=postgresql+psycopg://usuario:senha@127.0.0.1:5432/gestor_financeiro_prod
BOOTSTRAP_ADMIN_EMAIL=admin@example.invalid
BOOTSTRAP_ADMIN_PASSWORD=troque-isto-por-uma-senha-inicial-forte
SESSION_SECRET=troque-isto-por-um-segredo-forte
FIELD_ENCRYPTION_KEY=troque-isto-por-uma-chave-forte
MFA_ISSUER=Gestor Financeiro
SESSION_COOKIE_NAME=gestor_financeiro_session
MFA_TRUSTED_DEVICE_COOKIE_NAME=gestor_financeiro_mfa_device
SESSION_COOKIE_SAMESITE=lax
SESSION_HOURS=12
MFA_TRUSTED_DEVICE_DAYS=15
PENDING_AUTH_MINUTES=10
ALLOW_HEADER_AUTH=false
PUBLIC_ORIGIN=https://salomao.example.invalid
SECURITY_ALERT_EMAIL_ENABLED=false
SECURITY_ALERT_EMAIL_FROM=alerts@example.invalid
SECURITY_ALERT_EMAIL_TO=owner@example.invalid
SMTP_HOST=mail.example.invalid
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
IPINFO_TOKEN=
SECURITY_ALERT_ALLOWED_COUNTRIES=BR
SECURITY_ALERT_FAILURE_WINDOW_SECONDS=600
SECURITY_ALERT_FAILURE_THRESHOLD=3
SECURITY_ALERT_DEDUP_WINDOW_SECONDS=1800
LOGIN_RATE_LIMIT_ATTEMPTS=6
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
MFA_RATE_LIMIT_ATTEMPTS=8
MFA_RATE_LIMIT_WINDOW_SECONDS=300
BACKUP_ON_STARTUP=false
BACKUP_STARTUP_MIN_HOURS=12
BACKUP_BEFORE_IMPORTS=false
BACKUP_IMPORT_MIN_MINUTES=30
BACKUP_RETENTION_MAX_FILES=60
BACKUP_RETENTION_DAYS=120
SERVER_BACKUP_DIR=./server_backups
SERVER_BACKUP_ENCRYPTED=true
